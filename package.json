{
  "name": "chrome-extension-rejection-checker",
  "version": "0.1.0",
  "private": true,
  "description": "Free local Chrome Web Store rejection checker for Manifest V3 extension zip files.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "build:archives": "node scripts/build-archives.mjs"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "chrome-extension",
    "chrome-web-store",
    "manifest-v3",
    "rejection-checker",
    "remote-hosted-code"
  ],
  "license": "MIT"
}
