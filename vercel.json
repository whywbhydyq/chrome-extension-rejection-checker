{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/chrome-web-store-rejection-checker",
      "destination": "/chrome-web-store-rejection-checker/index.html"
    },
    {
      "source": "/manifest-v3-pre-submission-checklist",
      "destination": "/manifest-v3-pre-submission-checklist/index.html"
    },
    {
      "source": "/fix-remote-hosted-code-manifest-v3",
      "destination": "/fix-remote-hosted-code-manifest-v3/index.html"
    },
    {
      "source": "/chrome-extension-eval-rejection-fix",
      "destination": "/chrome-extension-eval-rejection-fix/index.html"
    },
    {
      "source": "/chrome-extension-host-permissions-privacy-review",
      "destination": "/chrome-extension-host-permissions-privacy-review/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
